# Go Waktu Solat API — environment configuration
# Copy to .env and edit as needed.

# Server port
PORT=8080

# SQLite database path
DB_PATH=data/waktusolat.db

# URL prefix (leave empty for no prefix)
BASE_PATH=

# CORS allowed origins — comma-separated, "*" for all.
#
# Single domain:
#   CORS_ORIGINS=https://example.com
#
# Multiple domains:
#   CORS_ORIGINS=https://example.com,https://admin.example.com,https://app.example.com
#
# Allow all (default):
#   CORS_ORIGINS=*
CORS_ORIGINS=*

# Prefork mode — spawns one process per CPU core.
# Safe with SQLite WAL mode (writes are rare and serialized).
# Set to "true" or "1" to enable (default: false).
PREFORK=false

# API key to protect /api/settings endpoints.
# If set, requests must include header: X-API-Key: <value>
# Leave empty (default) for no authentication on settings endpoints.
API_KEY=
